<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Otimizador Celular"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifique o uso do seu aparelho e libere espaço"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Card RAM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memória RAM"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRamInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Calculando..."
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressRam"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Armazenamento -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Armazenamento"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStorageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Calculando..."
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressStorage"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botão limpar cache -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimparCache"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Limpar cache deste app"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão gerenciar apps -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGerenciarApps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ver apps em segundo plano"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão configurações de armazenamento -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfigArmazenamento"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Abrir configurações de armazenamento"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apps instalados (toque para gerenciar)"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/containerApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nota: por segurança do Android, apps comuns não podem encerrar outros apps automaticamente. Toque em um app da lista para abrir a tela do sistema e finalizá-lo manualmente, se desejar."
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
