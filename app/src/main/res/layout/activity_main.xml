<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Otimizador Celular"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifique o uso do seu aparelho e libere espaço"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Card RAM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memória RAM"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRamInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Calculando..."
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressRam"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Armazenamento -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Armazenamento"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStorageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Calculando..."
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressStorage"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botão limpar cache do próprio app -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimparCache"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Limpar cache deste app"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão limpar cache de todos os apps -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimparCacheTodos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Limpar cache de todos os apps"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão fechar apps em segundo plano -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFecharSegundoPlano"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Fechar apps em segundo plano"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão modo jogo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModoJogo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ativar Modo Jogo (bloquear notificações)"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary_dark"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Card de dicas de desempenho -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dicas para melhorar o desempenho"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:text="• Reinicie o celular pelo menos uma vez por semana\n• Mantenha ao menos 10% do armazenamento livre\n• Desinstale apps que você não usa há meses\n• Reduza o número de widgets na tela inicial\n• Mantenha os apps atualizados (correções de desempenho)\n• Evite usar muitos apps 'limpadores de RAM' ao mesmo tempo — eles competem entre si e pioram o problema" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Barra do modo de limpeza de cache -->
        <LinearLayout
            android:id="@+id/barraModoLimpeza"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/accent"
            android:padding="12dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Modo limpeza: toque em um app, limpe o cache e volte"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConcluirLimpeza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concluir"
                android:textAllCaps="false"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

        <!-- Botão gerenciar apps -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGerenciarApps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ver apps em segundo plano"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão configurações de armazenamento -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfigArmazenamento"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Abrir configurações de armazenamento"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apps instalados (toque para gerenciar)"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/containerApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nota: por segurança do Android, apps comuns não podem encerrar outros apps automaticamente. Toque em um app da lista para abrir a tela do sistema e finalizá-lo manualmente, se desejar."
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
